#!/usr/bin/env python3
"""OpenRouter dynamic provider for maki.

Install: cp scripts/providers/openrouter ~/.maki/providers/openrouter && chmod +x ~/.maki/providers/openrouter
Usage:   maki -m openrouter/qwen/qwen3.6-plus:free
"""

import json
import os
import sys
import math
import urllib.request

OPENROUTER_API_KEY = os.environ.get("OPENROUTER_API_KEY", "")


def cmd_info():
    print(json.dumps({
        "display_name": "OpenRouter",
        "base": "openai",
        "has_auth": False,
    }))


def cmd_resolve():
    print(json.dumps({
        "base_url": "https://openrouter.ai/api/v1",
        "headers": {
            "authorization": f"Bearer {OPENROUTER_API_KEY}",
        },
    }))


def cmd_refresh():
    cmd_resolve()


def cmd_models():
    # Fetch popularity ordering from frontend endpoint
    popular_ids = _fetch_popular_ids()

    # Fetch full model data from official API
    url = "https://openrouter.ai/api/v1/models"
    headers = {"Authorization": f"Bearer {OPENROUTER_API_KEY}"} if OPENROUTER_API_KEY else {}

    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=15) as resp:
            data = json.loads(resp.read())
    except Exception:
        print(json.dumps([]))
        return

    # Build model entries for free, text-output models
    free_models = []
    for model in data.get("data", []):
        if not _is_text_only(model):
            continue
        if not _is_free(model):
            continue

        max_out = model.get("top_provider", {}).get("max_completion_tokens")
        if not max_out:
            max_out = 16384
        max_out = min(max_out, 65536)

        free_models.append({
            "id": model["id"],
            "context_window": model.get("context_length") or 128000,
            "max_output_tokens": max_out,
            "pricing": {
                "input": 0.0,
                "output": 0.0,
                "cache_write": 0.0,
                "cache_read": 0.0,
            },
        })

    if not free_models:
        print(json.dumps([]))
        return

    # Order by weekly popularity (popular first, then unknown ones)
    free_models.sort(key=lambda m: _popularity_rank(m["id"], popular_ids))

    # Assign tiers based on context_window percentiles across all models
    ctx_sorted = sorted(m["context_window"] for m in free_models)
    low = _percentile(ctx_sorted, 33)
    high = _percentile(ctx_sorted, 66)

    for m in free_models:
        if m["context_window"] >= high:
            m["tier"] = "strong"
        elif m["context_window"] >= low:
            m["tier"] = "medium"
        else:
            m["tier"] = "weak"

    print(json.dumps(free_models))


def _fetch_popular_ids():
    """Get model IDs ordered by weekly popularity (for free models)."""
    url = "https://openrouter.ai/api/frontend/models/find?max_price=0&order=top-weekly&input_modalities=text"
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        return [
            m["slug"] for m in data["data"]["models"]
            if m.get("output_modalities") == ["text"]
        ]
    except Exception:
        return []


def _popularity_rank(model_id: str, popular_ids: list) -> int:
    """Match model against popularity list. Handles :free suffix differences."""
    if model_id in popular_ids:
        return popular_ids.index(model_id)
    # Strip :free suffix for matching
    base = model_id.removesuffix(":free")
    if base in popular_ids:
        return popular_ids.index(base)
    return 999_999


def _is_free(model):
    pricing = model.get("pricing", {})
    prompt_price = float(pricing.get("prompt", "0") or "0")
    completion_price = float(pricing.get("completion", "0") or "0")
    return prompt_price == 0 and completion_price == 0


def _is_text_only(model):
    arch = model.get("architecture", {})
    output = arch.get("output_modalities", [])
    return output == ["text"]


def _percentile(sorted_vals, pct):
    """Nearest-rank percentile."""
    idx = int(math.ceil(pct / 100.0 * len(sorted_vals))) - 1
    return sorted_vals[max(0, idx)]


def main():
    if len(sys.argv) < 2:
        print(f"usage: {sys.argv[0]} <info|resolve|refresh|models>", file=sys.stderr)
        sys.exit(1)

    commands = {
        "info": cmd_info,
        "resolve": cmd_resolve,
        "refresh": cmd_refresh,
        "models": cmd_models,
    }

    fn = commands.get(sys.argv[1])
    if not fn:
        print(f"unknown command: {sys.argv[1]}", file=sys.stderr)
        sys.exit(1)
    fn()


if __name__ == "__main__":
    main()
